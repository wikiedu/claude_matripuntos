{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "Backend - Express",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "cwd": "${workspaceFolder}/src/backend",
      "autoPort": true,
      "env": {
        "NODE_ENV": "development"
      }
    },
    {
      "name": "Frontend - Vite",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "cwd": "${workspaceFolder}/src/frontend",
      "autoPort": true,
      "env": {
        "NODE_ENV": "development"
      }
    }
  ]
}
