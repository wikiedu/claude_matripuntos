{
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "strict": true,
    "noUnusedLocals": false,
    "noUnusedParameters": false,
    "types": ["node"],
    "lib": ["ES2022", "DOM"]
  },
  "include": ["specs/**/*.ts", "helpers/**/*.ts", "playwright.config.ts"]
}
