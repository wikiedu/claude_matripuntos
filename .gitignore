# Dependencies
node_modules/
yarn.lock
# package-lock.json: tracked intencionalmente para reproducibilidad de
# builds (CI + Render). Los workspaces npm viven en un único lockfile
# en la raíz; no añadir lockfiles por sub-paquete.

# Environment
.env
.env.local
.env.*.local

# Build outputs
dist/
build/
*.tsbuildinfo

# IDE
.vscode/
.idea/
*.swp
*.swo
*.swn
*.iml
.DS_Store
.env.*.local

# Logs
logs/
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Temp files
*.tmp
.cache/

# Visual companion brainstorm sessions
.superpowers/

# Database
prisma/migrations/

# OS
.DS_Store
Thumbs.db

# Testing
coverage/
.nyc_output/

