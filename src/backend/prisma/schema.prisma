// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "darwin", "windows"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Couples - Represents a couple registered in the app
model Couple {
  id                    String                   @id @default(cuid())
  secretKey             String                   @unique
  joinCode              String?                  @unique
  numChildren           Int                      @default(0)
  language              String                   @default("es")
  notificationsEnabled  Boolean                  @default(true)

  // Relations
  users                 User[]
  events                Event[]
  tasks                 Task[]
  taskLogs              TaskLog[]
  pointsTransactions    PointsTransaction[]
  compensations         Compensation[]
  configurations        Configuration?
  notifications         Notification[]
  subscriptions         Subscription?

  // V2 Relations
  profile               CoupleProfile?
  children              Child[]
  pets                  Pet[]
  invitations           Invitation[]
  categories            Category[]
  achievements          Achievement[]
  coupleScores          CoupleScore[]
  calendarEntries       CalendarEntry[]

  // v1.2 gamification fields
  xp                     Int       @default(0)
  level                  String    @default("encuentro")
  dailyStreakDays         Int       @default(0)
  weeklyStreakWeeks       Int       @default(0)
  dailyStreakFreezerUsed  Boolean   @default(false)
  lastActivityDate        DateTime?

  // v1.2 relations
  coupleAchievements      CoupleAchievement[]
  ruleProposals           RuleProposal[]

  // v1.3 relations
  shoppingLists           ShoppingList[]
  todos                   Todo[]

  // v1.6 relations
  moodLogs                MoodLog[]

  // v1.6.1 — Couple lifecycle: dissolvedAt marca la pareja como disuelta
  // tras "Salir de la pareja". Datos quedan accesibles read-only via
  // /api/history/past-couples.
  dissolvedAt           DateTime?

  // v1.7 gamification v2 relations
  coupleLevel           CoupleLevel?
  coupleStreak          CoupleStreak?
  coupleChallenges      CoupleChallenge[]
  pushSubscriptions     PushSubscription[]
  replaysSeen           CoupleReplaySeen[]
  serviceProviders      ServiceProvider[]

  // v2.0.2 relations
  journalEntries        JournalEntry[]
  journalRetrospectives JournalRetrospective[]

  // v2.0.3 relations
  analyticsInsights     AnalyticsInsight[]

  // v2.0.4 relations
  activityTemplates     ActivityTemplate[]
  configurationProposals ConfigurationProposal[]
  configurationChangeLog ConfigurationChangeLog[]

  // v2.0.5 — anniversary timer (fecha en la que la pareja "empezó"; null hasta que se setea)
  relationshipStartDate DateTime?

  // v2.2.8 — modo vacaciones (Claude Design canvas 14). Mientras pausedUntil
  // > now: streaks no se actualizan, digest no manda noti, dashboard muestra
  // banner '🏖️ Modo pausa hasta DD MMM'. El saldo se congela; al volver,
  // retoma donde estaba.
  pausedUntil           DateTime?
  pausedReason          String?

  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt

  @@index([secretKey])
  @@index([joinCode])
}

// v1.7 — Nivel de la pareja. XP es la suma de PointsTransaction.amount > 0.
// Level computado en backend (computeLevel) y cacheado aquí para reads.
model CoupleLevel {
  id        String   @id @default(cuid())
  coupleId  String   @unique
  couple    Couple   @relation(fields: [coupleId], references: [id], onDelete: Cascade)
  xp        Int      @default(0)
  level     Int      @default(1)
  updatedAt DateTime @updatedAt
}

// v1.7 — Streaks de pareja. dailyStreak suma días con ≥1 acción de cualquier
// user. weeklyStreak suma semanas con ≥3 acciones distribuidas en ≥3 días.
// longestX preservados aunque se rompa la racha (motivación intrínseca).
model CoupleStreak {
  id              String    @id @default(cuid())
  coupleId        String    @unique
  couple          Couple    @relation(fields: [coupleId], references: [id], onDelete: Cascade)
  dailyStreak     Int       @default(0)
  weeklyStreak    Int       @default(0)
  lastActivityAt  DateTime?
  longestDaily    Int       @default(0)
  longestWeekly   Int       @default(0)
  updatedAt       DateTime  @updatedAt
}

// v1.7 — Reto semanal generado los lunes 00:00 (TZ user) según nivel pareja.
// status = active | completed | expired. progress incrementa por evaluator.
model CoupleChallenge {
  id          String    @id @default(cuid())
  coupleId    String
  couple      Couple    @relation(fields: [coupleId], references: [id], onDelete: Cascade)
  weekStart   DateTime
  type        String    // balance | verify | diversity | no_dispute | high_impact
  config      String    // JSON con goal específico
  status      String    @default("active")
  progress    Int       @default(0)
  goal        Int
  rewardXp    Int
  completedAt DateTime?
  createdAt   DateTime  @default(now())

  @@unique([coupleId, weekStart])
  @@index([coupleId, status])
}

// v1.7 — Web push subscription endpoints. p256dh/auth son claves del browser.
model PushSubscription {
  id        String   @id @default(cuid())
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  coupleId  String
  couple    Couple   @relation(fields: [coupleId], references: [id], onDelete: Cascade)
  endpoint  String   @unique
  p256dh    String
  auth      String
  userAgent String?
  createdAt DateTime @default(now())

  @@index([userId])
}

// v1.7 — Tracking de replays vistos para no repetir 30d.
model CoupleReplaySeen {
  id         String   @id @default(cuid())
  coupleId   String
  couple     Couple   @relation(fields: [coupleId], references: [id], onDelete: Cascade)
  replayKey  String   // 'anniversary-2026-05-02' | 'best-day-2026-04-15'
  seenByUser1 Boolean @default(false)
  seenByUser2 Boolean @default(false)
  seenAt     DateTime @default(now())

  @@unique([coupleId, replayKey])
}

// Users - Individual members of a couple
model User {
  id                    String                   @id @default(cuid())
  coupleId              String?
  email                 String                   @unique
  passwordHash          String
  emailVerified         Boolean                  @default(false)
  verifiedAt            DateTime?

  name                  String
  roleInHome            String                   @default("equal")
  timezone              String                   @default("Europe/Madrid")
  language              String                   @default("es")
  notificationsPush     Boolean                  @default(true)
  notificationsEmail    Boolean                  @default(true)
  hasCompletedOnboarding Boolean                 @default(false)
  notificationPreferences String                 @default("{}")

  // Relations
  couple                Couple?                  @relation(fields: [coupleId], references: [id], onDelete: Cascade)
  profile               UserProfile?
  eventsCreated         Event[]                  @relation("createdBy")
  tasksCompleted        TaskLog[]                @relation("completedBy")
  tasksVerified         TaskLog[]                @relation("verifiedBy")
  negotiationsProposed  Negotiation[]            @relation("proposedBy")
  negotiationsResponded Negotiation[]            @relation("respondedBy")
  pointsTransactions    PointsTransaction[]
  notifications         Notification[]
  invitationsSent       Invitation[]             @relation("InvitationsSent")
  invitationsReceived   Invitation[]             @relation("InvitationsReceived")
  achievements          UserAchievement[]
  ruleProposalsSent       RuleProposal[]   @relation("ProposalsSent")
  ruleProposalsResponded  RuleProposal[]   @relation("ProposalsResponded")
  todos                   Todo[]
  premiumInterests        PremiumInterest[]

  // v1.6 relations
  moodLogs                MoodLog[]

  // v1.7 relations
  pushSubscriptions       PushSubscription[]

  // v2.0.1 relations
  googleCalendarSync      GoogleCalendarSync?

  // v2.0.2 relations
  journalEntriesAuthored  JournalEntry[]      @relation("JournalAuthor")
  journalEntriesReceived  JournalEntry[]      @relation("JournalRecipient")
  journalReactions        JournalReaction[]

  // v1.8-prep relations (refresh tokens)
  refreshTokens           RefreshToken[]

  // v2.0.4 relations
  configurationProposals  ConfigurationProposal[] @relation("ConfigProposer")
  configurationChangesApplied ConfigurationChangeLog[]

  // v1.6.1 — User lifecycle:
  //  - deletedAt: soft delete papelera 30d antes de hard purge.
  //  - firstLoginAt: para timer del banner "Completa tu perfil" del invitado.
  deletedAt             DateTime?
  firstLoginAt          DateTime?

  lastLogin             DateTime?
  lastSeenAt            DateTime?
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt

  @@index([coupleId])
  @@index([email])
}

// Events - Actividades puntuales (ausencias/eventos)
model Event {
  id                    String                   @id @default(cuid())
  coupleId              String
  createdBy             String?

  type                  String                   // cena, viaje, despedida, etc.
  title                 String?
  description           String?

  dateStart             DateTime
  dateEnd               DateTime

  hasChildren           Boolean                  @default(false)
  numChildren           Int                      @default(0)

  pointsBase            Decimal
  pointsCalculated      Decimal
  pointsAgreed          Decimal?

  status                String                   @default("draft")
  negotiationRound      Int                      @default(0)
  maxFreeRounds         Int                      @default(99)  // MVP: no premium plan yet, effectively unlimited
  currentNegotiationRound Int                    @default(0)
  lastProposedBy        String?
  lastProposedPoints    Decimal?
  negotiationHistory    String                   @default("[]")  // JSON array of negotiation rounds
  justification         String?                  // Reason for counter-proposal

  compensation          String?
  compensationDiscount  Decimal                  @default(1.0)

  // Relations
  couple                Couple                   @relation(fields: [coupleId], references: [id], onDelete: Cascade)
  creator               User?                    @relation("createdBy", fields: [createdBy], references: [id], onDelete: SetNull)
  negotiations          Negotiation[]
  compensations         Compensation[]
  pointsTransactions    PointsTransaction[]
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt

  @@index([coupleId])
  @@index([createdBy])
  @@index([status])
  @@index([dateStart])
}

// Tasks - Tareas recurrentes diarias
model Task {
  id                    String                   @id @default(cuid())
  coupleId              String
  name                  String
  description           String?
  category              String                   // cocina, limpieza, baños, compra, logística, cuidado

  pointsBase            Decimal                  @default(1.0)
  isDefault             Boolean                  @default(false)

  // v1.3 scheduling & recurrence
  scheduledFor          DateTime?
  isRecurring           Boolean                  @default(false)
  frequency             String?                  // daily | biweekly | weekly | bimonthly | monthly
  recurrenceStart       DateTime?
  recurrenceEnd         DateTime?
  maxOccurrences        Int?
  occurrenceCount       Int                      @default(0)

  // v1.5 quick-win #3 — default assignee for the task (nullable = either)
  defaultAssigneeId     String?

  // Relations
  couple                Couple                   @relation(fields: [coupleId], references: [id], onDelete: Cascade)
  logs                  TaskLog[]
  compensations         Compensation[]

  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt

  @@index([coupleId])
  @@index([category])
}

// TaskLogs - Registro de tareas completadas
model TaskLog {
  id                    String                   @id @default(cuid())
  coupleId              String
  taskId                String
  completedBy           String?

  date                  DateTime
  scheduledFor          DateTime?
  isAutoGenerated       Boolean                  @default(false)

  pointsBase            Decimal
  modifier              String?
  modifierValue         Decimal                  @default(0)
  pointsFinal           Decimal

  status                String                   @default("pending")
  verifiedBy            String?
  verifiedAt            DateTime?

  disputeReason         String?
  disputedAt            DateTime?
  pointsDisputed        Decimal?

  // v2.0.5 — image proof opcional (URL https). No se sube binario al backend; se
  // espera URL ya hosteada (cloud storage del usuario o data-URL pequeño <500KB)
  proofImageUrl         String?
  proofUploadedAt       DateTime?

  // Relations
  couple                Couple                   @relation(fields: [coupleId], references: [id], onDelete: Cascade)
  task                  Task                     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  completedByUser       User?                    @relation("completedBy", fields: [completedBy], references: [id], onDelete: SetNull)
  verifiedByUser        User?                    @relation("verifiedBy", fields: [verifiedBy], references: [id], onDelete: SetNull)
  pointsTransaction     PointsTransaction?

  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt

  @@index([coupleId])
  @@index([completedBy])
  @@index([date])
  @@index([status])
  @@index([scheduledFor])
}

// Negotiations - Historial de negociaciones
model Negotiation {
  id                    String                   @id @default(cuid())
  eventId               String
  roundNumber           Int

  proposedBy            String?
  pointsProposed        Decimal
  message               String?

  responseType          String?                  // accepted, rejected, counter_proposed, awaiting, forced
  respondedBy           String?
  respondedAt           DateTime?

  // Relations
  event                 Event                    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  proposer              User?                    @relation("proposedBy", fields: [proposedBy], references: [id], onDelete: SetNull)
  responder             User?                    @relation("respondedBy", fields: [respondedBy], references: [id], onDelete: SetNull)

  createdAt             DateTime                 @default(now())

  @@index([eventId])
  @@index([proposedBy])
  @@index([roundNumber])
}

// PointsTransactions - Ledger of all points changes
model PointsTransaction {
  id                    String                   @id @default(cuid())
  coupleId              String
  userId                String?

  type                  String                   // event_accepted, task_completed, donation, forced_payment, etc.
  relatedEventId        String?
  relatedTaskLogId      String?                  @unique

  amount                Decimal
  description           String?

  // Relations
  couple                Couple                   @relation(fields: [coupleId], references: [id], onDelete: Cascade)
  user                  User?                    @relation(fields: [userId], references: [id], onDelete: SetNull)
  taskLog               TaskLog?                 @relation(fields: [relatedTaskLogId], references: [id], onDelete: SetNull)
  event                 Event?                   @relation(fields: [relatedEventId], references: [id], onDelete: SetNull)

  createdAt             DateTime                 @default(now())

  @@index([coupleId])
  @@index([userId])
  @@index([type])
  @@index([relatedEventId])
  @@index([createdAt])
}

// Compensations - Descuentos y compensaciones
model Compensation {
  id                    String                   @id @default(cuid())
  eventId               String
  coupleId              String

  type                  String                   // cocina, canguro, levantarse, tarea_futura, etc.
  description           String?

  discountAmount        Decimal
  discountPercent       Decimal?

  status                String                   @default("pending")

  linkedTaskId          String?
  dueDate               DateTime?
  completedAt           DateTime?

  // Relations
  event                 Event                    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  couple                Couple                   @relation(fields: [coupleId], references: [id], onDelete: Cascade)
  linkedTask            Task?                    @relation(fields: [linkedTaskId], references: [id], onDelete: SetNull)

  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt

  @@index([eventId])
  @@index([status])
}

// Configurations - Per-couple settings
model Configuration {
  id                    String                   @id @default(cuid())
  coupleId              String                   @unique

  tasksConfig           String                   @default("{}")
  multipliersConfig     String                   @default("{}")
  activityTypes         String                   @default("{}")

  // Relations
  couple                Couple                   @relation(fields: [coupleId], references: [id], onDelete: Cascade)

  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt

  @@index([coupleId])
}

// Notifications - In-app notification inbox
model Notification {
  id                    String                   @id @default(cuid())
  coupleId              String
  userId                String

  type                  String
  title                 String
  message               String

  relatedEventId        String?
  relatedTaskLogId      String?

  isRead                Boolean                  @default(false)
  readAt                DateTime?

  // Relations
  couple                Couple                   @relation(fields: [coupleId], references: [id], onDelete: Cascade)
  user                  User                     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt             DateTime                 @default(now())

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}

// Subscriptions - Plan premium
model Subscription {
  id                    String                   @id @default(cuid())
  coupleId              String                   @unique

  plan                  String                   @default("free")

  startedAt             DateTime                 @default(now())
  endsAt                DateTime?

  stripeId              String?

  // Relations
  couple                Couple                   @relation(fields: [coupleId], references: [id], onDelete: Cascade)

  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt

  @@index([coupleId])
  @@index([endsAt])
}

// UserProfile - Extended user data (V2)
model UserProfile {
  id                    String                   @id @default(cuid())
  userId                String                   @unique

  surname               String?
  profilePhotoUrl       String?
  dateOfBirth           DateTime?

  // Work info
  weeklyWorkHours       Int                      @default(40)
  workMode              String                   @default("presencial")  // presencial, teletrabajo, hibrido
  workSchedule          String?                  // JSON string

  // Preferences
  taskPreferencesLoves  String                   @default("[]")  // JSON array
  taskPreferencesDislikes String                 @default("[]")  // JSON array

  // Avatar & personalization (v1.1)
  avatarEmoji    String   @default("🐼")
  avatarColor    String   @default("#7c3aed")
  theme          String   @default("dark")

  // Mood del día (v1.1)
  currentMood    String?
  moodUpdatedAt  DateTime?

  // Relations
  user                  User                     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt

  @@index([userId])
}

// CoupleProfile - Home/household data (V2)
model CoupleProfile {
  id                    String                   @id @default(cuid())
  coupleId              String                   @unique

  homeType              String?                  // piso, casa, otro
  homeSizeM2            Int?

  cohabitation          String?                  // JSON string
  externalServices      String?                  // JSON string (cleaners, babysitters, etc)

  isActive              Boolean                  @default(true)

  // Relations
  couple                Couple                   @relation(fields: [coupleId], references: [id], onDelete: Cascade)

  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt

  @@index([coupleId])
}

// Child - Children management (V2)
model Child {
  id                    String                   @id @default(cuid())
  coupleId              String

  name                  String
  dateOfBirth           DateTime
  livesWithUser1        Boolean                  @default(true)
  livesWithUser2        Boolean                  @default(true)
  hasSpecialNeeds       Boolean                  @default(false)

  // Relations
  couple                Couple                   @relation(fields: [coupleId], references: [id], onDelete: Cascade)

  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt

  @@index([coupleId])
}

// Pet - Pets management (V2)
model Pet {
  id                    String                   @id @default(cuid())
  coupleId              String

  name                  String
  type                  String                   // perro, gato, otro
  quantity              Int                      @default(1)

  // Relations
  couple                Couple                   @relation(fields: [coupleId], references: [id], onDelete: Cascade)

  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt

  @@index([coupleId])
}

// Invitation - Partner invitation system (V2)
model Invitation {
  id                    String                   @id @default(cuid())
  fromUserId            String
  toEmail               String?
  toUserId              String?
  token                 String                   @unique
  type                  String                   // "email_invite" | "user_proposal"
  status                String                   @default("pending")  // pending, accepted, rejected
  coupleId              String?
  expiresAt             DateTime

  // Relations
  fromUser              User                     @relation("InvitationsSent", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser                User?                    @relation("InvitationsReceived", fields: [toUserId], references: [id], onDelete: Cascade)
  couple                Couple?                  @relation(fields: [coupleId], references: [id], onDelete: SetNull)

  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt

  @@index([fromUserId])
  @@index([toEmail])
  @@index([toUserId])
  @@index([token])
  @@index([expiresAt])
}

// Category - Event/Task categories (V2)
model Category {
  id                    String                   @id @default(cuid())
  coupleId              String

  name                  String
  emoji                 String
  type                  String                   // event, chore, service
  basePoints            Decimal                  @default(10)
  description           String?

  isCustom              Boolean                  @default(false)  // false = base, true = couple created
  isActive              Boolean                  @default(true)

  // Relations
  couple                Couple                   @relation(fields: [coupleId], references: [id], onDelete: Cascade)
  subcategories         Subcategory[]

  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt

  @@index([coupleId])
  @@index([type])
  @@index([isCustom])
}

// Subcategory - Event/Task subcategories (V2)
model Subcategory {
  id                    String                   @id @default(cuid())
  categoryId            String

  name                  String
  basePointsModifier    Decimal                  @default(0)  // Can be +5, -3, ×1.2 etc

  // Relations
  category              Category                 @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt

  @@index([categoryId])
}

// Achievement - Gamification achievements (V2)
model Achievement {
  id                    String                   @id @default(cuid())
  coupleId              String

  type                  String                   // solo, couple
  name                  String
  description           String
  icon                  String
  rarity                String                   // common, rare, epic, legendary
  condition             String?                  // JSON condition

  // Relations
  couple                Couple                   @relation(fields: [coupleId], references: [id], onDelete: Cascade)
  userAchievements      UserAchievement[]

  createdAt             DateTime                 @default(now())

  @@index([coupleId])
  @@index([type])
}

// UserAchievement - When user unlocked achievement (V2)
model UserAchievement {
  id                    String                   @id @default(cuid())
  userId                String
  achievementId         String

  // Relations
  user                  User?                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement           Achievement              @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  unlockedAt            DateTime                 @default(now())

  @@unique([userId, achievementId])
  @@index([userId])
  @@index([achievementId])
}

// CoupleScore - Weekly couple score snapshots (V2)
model CoupleScore {
  id                    String                   @id @default(cuid())
  coupleId              String

  weekStartDate         DateTime
  user1Score            Decimal                  @default(50)
  user2Score            Decimal                  @default(50)
  overallScore          Decimal                  @default(50)

  equilibrium           Decimal                  @default(0)
  activity              Decimal                  @default(0)
  consensus             Decimal                  @default(0)
  constancy             Decimal                  @default(0)

  // Relations
  couple                Couple                   @relation(fields: [coupleId], references: [id], onDelete: Cascade)

  createdAt             DateTime                 @default(now())

  @@unique([coupleId, weekStartDate])
  @@index([coupleId])
  @@index([weekStartDate])
}

// CalendarEntry - Calendar events (V2)
model CalendarEntry {
  id                    String                   @id @default(cuid())
  coupleId              String

  type                  String                   // event | task | service | birthday | holiday | external
  title                 String
  date                  DateTime
  endDate               DateTime?
  allDay                Boolean                  @default(true)

  relatedEventId        String?
  relatedTaskId         String?
  description           String?
  color                 String?
  category              String?

  // v2.0.1 — Calendario 360
  externalSource        String?                  // 'google_calendar' | 'manual' | 'auto'
  externalId            String?                  // ID del provider (Google event id)
  recurrence            String?                  // RRULE simplificado subset RFC 5545
  metadata              String?                  // JSON: { childId?, serviceProviderId?, taskId? }

  // Relations
  couple                Couple                   @relation(fields: [coupleId], references: [id], onDelete: Cascade)

  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt @default(now())

  @@index([coupleId])
  @@index([date])
  @@index([type])
  @@index([coupleId, date])
  @@index([coupleId, type])
  @@unique([externalSource, externalId])
}

// v2.0.1 — Sincronización Google Calendar por user (read-only OAuth).
// refreshToken cifrado AES-256-GCM con GOOGLE_TOKEN_ENCRYPTION_KEY.
model GoogleCalendarSync {
  id            String   @id @default(cuid())
  userId        String   @unique
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshToken  String   // cifrado: iv:authTag:cipher base64
  scope         String
  syncEnabled   Boolean  @default(true)
  lastSyncedAt  DateTime?
  lastSyncToken String?  // sync incremental Google
  syncWindow    Int      @default(90)  // días forward + backward
  filters       String   @default("[]")  // JSON whitelist calendarIds
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

// v2.0.1 — Proveedores externos recurrentes (limpieza, jardinería, etc).
// recurrence en RRULE simplificado se expande a CalendarEntry.
model ServiceProvider {
  id          String   @id @default(cuid())
  coupleId    String
  couple      Couple   @relation(fields: [coupleId], references: [id], onDelete: Cascade)
  name        String
  type        String   // limpieza | jardineria | cuidado_ninos | mantenimiento | otro
  recurrence  String?  // RRULE
  color       String?
  active      Boolean  @default(true)
  notes       String?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([coupleId, active])
}

// v2.0.2 — Journaling. Bitácora pareja con entries individuales/compartidas.
model JournalEntry {
  id              String   @id @default(cuid())
  coupleId        String
  couple          Couple   @relation(fields: [coupleId], references: [id], onDelete: Cascade)
  authorId        String
  author          User     @relation("JournalAuthor", fields: [authorId], references: [id], onDelete: Cascade)
  type            String   // reflection | photo | voice | milestone | letter
  title           String?
  body            String?
  shared          Boolean  @default(false)
  attachments     String   @default("[]")  // JSON array
  tags            String   @default("[]")  // JSON array of strings
  promptId        String?
  prompt          JournalPrompt? @relation(fields: [promptId], references: [id])
  recipientId     String?
  recipient       User?    @relation("JournalRecipient", fields: [recipientId], references: [id])
  readByPartnerAt DateTime?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  reactions       JournalReaction[]

  @@index([coupleId, createdAt])
  @@index([authorId, createdAt])
}

model JournalReaction {
  id        String   @id @default(cuid())
  entryId   String
  entry     JournalEntry @relation(fields: [entryId], references: [id], onDelete: Cascade)
  userId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  emoji     String
  createdAt DateTime @default(now())

  @@unique([entryId, userId, emoji])
}

model JournalPrompt {
  id        String   @id  // 'q-001'
  text      String
  category  String   // reflection | gratitude | future | conflict | celebration
  weight    Int      @default(1)

  entries   JournalEntry[]
}

model JournalRetrospective {
  id          String   @id @default(cuid())
  coupleId    String
  couple      Couple   @relation(fields: [coupleId], references: [id], onDelete: Cascade)
  period      String   // week | month | year
  startDate   DateTime
  endDate     DateTime
  data        String   // JSON con stats agregadas
  generatedAt DateTime @default(now())
  seenByUser1 Boolean  @default(false)
  seenByUser2 Boolean  @default(false)

  @@unique([coupleId, period, startDate])
}

// v1.8-prep — Refresh tokens para rotación de JWT (S1-6 audit).
// Esquema preparado pero NO activo en producción aún. Activación requiere
// reducir JWT_EXPIRY a 1h y añadir interceptor frontend en una versión
// dedicada (riesgo de romper sesiones actuales). Ver docs/STATUS.md §5.
model RefreshToken {
  id            String   @id @default(cuid())
  userId        String
  user          User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash     String   @unique  // SHA-256 hex del refresh token (no almacenamos el plaintext)
  expiresAt     DateTime
  revokedAt     DateTime?
  rotatedFrom   String?           // id del refresh token previo en la cadena de rotation
  deviceFingerprint String?       // user-agent + IP hash opcional para detectar reuse
  createdAt     DateTime @default(now())
  lastUsedAt    DateTime?

  @@index([userId])
  @@index([expiresAt])
}

// v2.0.3 — Analytics Pro insights cache. Generadas por cron diario.
// validUntil expira la card → cron la regenera. Rotación visible al user
// vía seenAt: solo se muestran las cards no vistas (prioridad) o vistas
// hace >24h.
model AnalyticsInsight {
  id          String   @id @default(cuid())
  coupleId    String
  couple      Couple   @relation(fields: [coupleId], references: [id], onDelete: Cascade)
  kind        String   // 'time-of-day' | 'top-category' | 'streak-broken' | 'weekly-balance' | etc.
  title       String
  body        String
  payload     String   @default("{}")  // JSON con números/refs concretos
  trend       String?  // 'up' | 'down' | 'flat'
  generatedAt DateTime @default(now())
  validUntil  DateTime
  seenByUser1 Boolean  @default(false)
  seenByUser2 Boolean  @default(false)

  @@index([coupleId, validUntil])
  @@index([coupleId, kind])
}

// v2.0.4 — Catálogo de actividades. Templates seed + custom de couple.
// 2 niveles: category → subcategory. Pre-fill pointsBaseSuggested editable.
model ActivityTemplate {
  id                    String   @id @default(cuid())
  // Ámbito: si coupleId is null, es seed global; si tiene valor, es custom de ese couple.
  coupleId              String?
  couple                Couple?  @relation(fields: [coupleId], references: [id], onDelete: Cascade)
  category              String   // gastronomia | cuidado | logistica | salud | ocio | mantenimiento | viaje | otros
  subcategory           String?  // ej: "Cita médica", "Despertar nocturno", "Compra grande"
  name                  String
  description           String?
  pointsBaseSuggested   Decimal  @default(10.0)  // sugerencia editable al crear Event
  defaultDurationMinutes Int?
  defaultImpact         String?  // 'necesaria' | 'salud' | 'ocio' | 'alto-impacto'
  emoji                 String?
  isActive              Boolean  @default(true)
  // v2.0.4: instances counter actualizado por trigger backend al crear Event
  // que referencia este template. Solo para CUSTOM templates (per couple).
  instancesThisMonth    Int      @default(0)
  lastInstanceAt        DateTime?
  // v2.1.1: consenso híbrido (opción C). Los templates globales (coupleId=null)
  // vienen pre-aprobados. Los custom de pareja entran con pointsApproved=false
  // hasta que el partner acepte mediante una ConfigurationProposal con field
  // 'activity_template:<id>:points'.
  pointsApproved        Boolean   @default(false)
  pointsApprovedAt      DateTime?
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt

  @@index([coupleId, isActive])
  @@index([category])
}

// v2.0.4 — Propuesta de cambio de configuración consensuada.
// Status active → accepted | rejected | expired (timeout 7d).
// Cap 3 propuestas active por user (rate-limit en route).
model ConfigurationProposal {
  id           String   @id @default(cuid())
  coupleId     String
  couple       Couple   @relation(fields: [coupleId], references: [id], onDelete: Cascade)
  proposedById String
  proposedBy   User     @relation("ConfigProposer", fields: [proposedById], references: [id], onDelete: Cascade)
  field        String   // 'multipliersConfig.nightMult' | 'taskBasePoints.cocina' | 'reset_factory'
  oldValue     String   // JSON
  newValue     String   // JSON
  rationale    String?  // razón opcional explicada al partner
  status       String   @default("active")  // active | accepted | rejected | expired
  respondedById String?
  respondedAt  DateTime?
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  @@index([coupleId, status])
  @@index([expiresAt])
}

// v2.0.4 — Histórico de cambios aplicados (cuando ConfigurationProposal acepta).
// Visible en Settings → Reglas → "Log de cambios" últimas 10.
model ConfigurationChangeLog {
  id          String   @id @default(cuid())
  coupleId    String
  couple      Couple   @relation(fields: [coupleId], references: [id], onDelete: Cascade)
  field       String
  oldValue    String   // JSON
  newValue    String   // JSON
  appliedById String
  appliedBy   User     @relation(fields: [appliedById], references: [id], onDelete: Cascade)
  proposalId  String?
  appliedAt   DateTime @default(now())

  @@index([coupleId, appliedAt])
}

// AchievementDefinition — global achievement catalog (v1.2)
model AchievementDefinition {
  id          String   @id @default(cuid())
  name        String
  description String
  icon        String   // emoji
  rarity      String   // common | rare | epic | legendary
  category    String   // constancia | equilibrio | consenso | rendimiento | pareja | secretos
  condition   String   // JSON: { type, threshold, ... }
  xpReward    Int      @default(50)
  orderIndex  Int      @default(0)

  coupleAchievements CoupleAchievement[]

  createdAt   DateTime @default(now())

  @@index([category])
  @@index([orderIndex])
}

// CoupleAchievement — per-couple progress on AchievementDefinitions (v1.2)
model CoupleAchievement {
  id                      String   @id @default(cuid())
  coupleId                String
  achievementDefinitionId String

  progress                String?  // JSON: { current, target }
  unlockedAt              DateTime?

  couple                  Couple                @relation(fields: [coupleId], references: [id], onDelete: Cascade)
  definition              AchievementDefinition @relation(fields: [achievementDefinitionId], references: [id], onDelete: Cascade)

  @@unique([coupleId, achievementDefinitionId])
  @@index([coupleId])
}

// RuleProposal — bilateral proposal flow for rules and categories (v1.2)
model RuleProposal {
  id               String   @id @default(cuid())
  coupleId         String
  proposedById     String?
  respondedById    String?

  type             String   // rule | category | category_edit
  payload          String   // JSON
  proposerComment  String?

  status           String   @default("pending") // pending | accepted | rejected
  responderComment String?
  respondedAt      DateTime?

  couple           Couple   @relation(fields: [coupleId], references: [id], onDelete: Cascade)
  proposedBy       User?    @relation("ProposalsSent", fields: [proposedById], references: [id], onDelete: SetNull)
  respondedBy      User?    @relation("ProposalsResponded", fields: [respondedById], references: [id], onDelete: SetNull)

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  @@index([coupleId])
  @@index([status])
  @@index([proposedById])
}

// v1.3 Shopping List
model ShoppingList {
  id         String         @id @default(cuid())
  coupleId   String
  isActive   Boolean        @default(true)
  archivedAt DateTime?
  createdAt  DateTime       @default(now())

  couple     Couple         @relation(fields: [coupleId], references: [id], onDelete: Cascade)
  items      ShoppingItem[]

  @@index([coupleId])
}

model ShoppingItem {
  id        String       @id @default(cuid())
  listId    String
  text      String
  isChecked Boolean      @default(false)
  checkedBy String?
  checkedAt DateTime?
  createdAt DateTime     @default(now())

  list      ShoppingList @relation(fields: [listId], references: [id], onDelete: Cascade)

  @@index([listId])
}

// v1.3 Personal To-dos
model Todo {
  id          String    @id @default(cuid())
  userId      String
  coupleId    String
  text        String
  isCompleted Boolean   @default(false)
  completedAt DateTime?
  dueDate     DateTime?
  isShared    Boolean   @default(false)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  couple      Couple    @relation(fields: [coupleId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([coupleId])
}

// v1.4 La Evolución — captura de interés en funciones Premium
model PremiumInterest {
  id        String   @id @default(uuid())
  email     String
  userId    String?
  coupleId  String?
  source    String
  createdAt DateTime @default(now())
  notified  Boolean  @default(false)

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([email])
  @@index([notified])
}

// v1.6 — Mood log: histórico personal de moods. Sirve para MyMoodWeek.
model MoodLog {
  id        String   @id @default(uuid())
  userId    String
  coupleId  String
  moodKey   String
  createdAt DateTime @default(now())

  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  couple    Couple   @relation(fields: [coupleId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([coupleId, createdAt])
}
