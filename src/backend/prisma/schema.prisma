// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "darwin", "windows"]
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Couples - Represents a couple registered in the app
model Couple {
  id                    String                   @id @default(cuid())
  secretKey             String                   @unique
  numChildren           Int                      @default(0)
  language              String                   @default("es")
  notificationsEnabled  Boolean                  @default(true)

  // Relations
  users                 User[]
  events                Event[]
  tasks                 Task[]
  taskLogs              TaskLog[]
  pointsTransactions    PointsTransaction[]
  compensations         Compensation[]
  configurations        Configuration?
  notifications         Notification[]
  subscriptions         Subscription?

  // V2 Relations
  profile               CoupleProfile?
  children              Child[]
  pets                  Pet[]
  invitations           Invitation[]
  categories            Category[]
  achievements          Achievement[]
  coupleScores          CoupleScore[]
  calendarEntries       CalendarEntry[]

  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt

  @@index([secretKey])
}

// Users - Individual members of a couple
model User {
  id                    String                   @id @default(cuid())
  coupleId              String?
  email                 String                   @unique
  passwordHash          String
  emailVerified         Boolean                  @default(false)
  verifiedAt            DateTime?

  name                  String
  roleInHome            String                   @default("equal")
  timezone              String                   @default("Europe/Madrid")
  language              String                   @default("es")
  notificationsPush     Boolean                  @default(true)
  notificationsEmail    Boolean                  @default(true)
  hasCompletedOnboarding Boolean                 @default(false)
  notificationPreferences String                 @default("{}")

  // Relations
  couple                Couple?                  @relation(fields: [coupleId], references: [id], onDelete: Cascade)
  profile               UserProfile?
  eventsCreated         Event[]                  @relation("createdBy")
  tasksCompleted        TaskLog[]                @relation("completedBy")
  tasksVerified         TaskLog[]                @relation("verifiedBy")
  negotiationsProposed  Negotiation[]            @relation("proposedBy")
  negotiationsResponded Negotiation[]            @relation("respondedBy")
  pointsTransactions    PointsTransaction[]
  notifications         Notification[]
  invitationsSent       Invitation[]             @relation("InvitationsSent")
  invitationsReceived   Invitation[]             @relation("InvitationsReceived")
  achievements          UserAchievement[]

  lastLogin             DateTime?
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt

  @@index([coupleId])
  @@index([email])
}

// Events - Actividades puntuales (ausencias/eventos)
model Event {
  id                    String                   @id @default(cuid())
  coupleId              String
  createdBy             String?

  type                  String                   // cena, viaje, despedida, etc.
  title                 String?
  description           String?

  dateStart             DateTime
  dateEnd               DateTime

  hasChildren           Boolean                  @default(false)
  numChildren           Int                      @default(0)

  pointsBase            Decimal
  pointsCalculated      Decimal
  pointsAgreed          Decimal?

  status                String                   @default("draft")
  negotiationRound      Int                      @default(0)
  maxFreeRounds         Int                      @default(2)
  currentNegotiationRound Int                    @default(0)
  lastProposedBy        String?
  lastProposedPoints    Decimal?
  negotiationHistory    String                   @default("[]")  // JSON array of negotiation rounds
  justification         String?                  // Reason for counter-proposal

  compensation          String?
  compensationDiscount  Decimal                  @default(1.0)

  // Relations
  couple                Couple                   @relation(fields: [coupleId], references: [id], onDelete: Cascade)
  creator               User?                    @relation("createdBy", fields: [createdBy], references: [id], onDelete: SetNull)
  negotiations          Negotiation[]
  compensations         Compensation[]
  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt

  @@index([coupleId])
  @@index([createdBy])
  @@index([status])
  @@index([dateStart])
}

// Tasks - Tareas recurrentes diarias
model Task {
  id                    String                   @id @default(cuid())
  coupleId              String
  name                  String
  description           String?
  category              String                   // cocina, limpieza, baños, compra, logística, cuidado

  pointsBase            Decimal                  @default(1.0)
  isDefault             Boolean                  @default(false)

  // Relations
  couple                Couple                   @relation(fields: [coupleId], references: [id], onDelete: Cascade)
  logs                  TaskLog[]
  compensations         Compensation[]

  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt

  @@index([coupleId])
  @@index([category])
}

// TaskLogs - Registro de tareas completadas
model TaskLog {
  id                    String                   @id @default(cuid())
  coupleId              String
  taskId                String
  completedBy           String?

  date                  DateTime

  pointsBase            Decimal
  modifier              String?
  modifierValue         Decimal                  @default(0)
  pointsFinal           Decimal

  status                String                   @default("pending")
  verifiedBy            String?
  verifiedAt            DateTime?

  disputeReason         String?
  disputedAt            DateTime?
  pointsDisputed        Decimal?

  // Relations
  couple                Couple                   @relation(fields: [coupleId], references: [id], onDelete: Cascade)
  task                  Task                     @relation(fields: [taskId], references: [id], onDelete: Cascade)
  completedByUser       User?                    @relation("completedBy", fields: [completedBy], references: [id], onDelete: SetNull)
  verifiedByUser        User?                    @relation("verifiedBy", fields: [verifiedBy], references: [id], onDelete: SetNull)
  pointsTransaction     PointsTransaction?

  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt

  @@unique([coupleId, taskId, date, completedBy])
  @@index([coupleId])
  @@index([completedBy])
  @@index([date])
  @@index([status])
}

// Negotiations - Historial de negociaciones
model Negotiation {
  id                    String                   @id @default(cuid())
  eventId               String
  roundNumber           Int

  proposedBy            String?
  pointsProposed        Decimal
  message               String?

  responseType          String?                  // accepted, rejected, counter_proposed, awaiting, forced
  respondedBy           String?
  respondedAt           DateTime?

  // Relations
  event                 Event                    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  proposer              User?                    @relation("proposedBy", fields: [proposedBy], references: [id], onDelete: SetNull)
  responder             User?                    @relation("respondedBy", fields: [respondedBy], references: [id], onDelete: SetNull)

  createdAt             DateTime                 @default(now())

  @@index([eventId])
  @@index([proposedBy])
  @@index([roundNumber])
}

// PointsTransactions - Ledger of all points changes
model PointsTransaction {
  id                    String                   @id @default(cuid())
  coupleId              String
  userId                String?

  type                  String                   // event_accepted, task_completed, donation, forced_payment, etc.
  relatedEventId        String?
  relatedTaskLogId      String?                  @unique

  amount                Decimal
  description           String?

  // Relations
  couple                Couple                   @relation(fields: [coupleId], references: [id], onDelete: Cascade)
  user                  User?                    @relation(fields: [userId], references: [id], onDelete: SetNull)
  taskLog               TaskLog?                 @relation(fields: [relatedTaskLogId], references: [id], onDelete: SetNull)

  createdAt             DateTime                 @default(now())

  @@index([coupleId])
  @@index([userId])
  @@index([type])
  @@index([relatedEventId])
  @@index([createdAt])
}

// Compensations - Descuentos y compensaciones
model Compensation {
  id                    String                   @id @default(cuid())
  eventId               String
  coupleId              String

  type                  String                   // cocina, canguro, levantarse, tarea_futura, etc.
  description           String?

  discountAmount        Decimal
  discountPercent       Decimal?

  status                String                   @default("pending")

  linkedTaskId          String?
  dueDate               DateTime?
  completedAt           DateTime?

  // Relations
  event                 Event                    @relation(fields: [eventId], references: [id], onDelete: Cascade)
  couple                Couple                   @relation(fields: [coupleId], references: [id], onDelete: Cascade)
  linkedTask            Task?                    @relation(fields: [linkedTaskId], references: [id], onDelete: SetNull)

  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt

  @@index([eventId])
  @@index([status])
}

// Configurations - Per-couple settings
model Configuration {
  id                    String                   @id @default(cuid())
  coupleId              String                   @unique

  tasksConfig           String                   @default("{}")
  multipliersConfig     String                   @default("{}")
  activityTypes         String                   @default("{}")

  // Relations
  couple                Couple                   @relation(fields: [coupleId], references: [id], onDelete: Cascade)

  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt

  @@index([coupleId])
}

// Notifications - In-app notification inbox
model Notification {
  id                    String                   @id @default(cuid())
  coupleId              String
  userId                String

  type                  String
  title                 String
  message               String

  relatedEventId        String?
  relatedTaskLogId      String?

  isRead                Boolean                  @default(false)
  readAt                DateTime?

  // Relations
  couple                Couple                   @relation(fields: [coupleId], references: [id], onDelete: Cascade)
  user                  User                     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt             DateTime                 @default(now())

  @@index([userId])
  @@index([isRead])
  @@index([createdAt])
}

// Subscriptions - Plan premium
model Subscription {
  id                    String                   @id @default(cuid())
  coupleId              String                   @unique

  plan                  String                   @default("free")

  startedAt             DateTime                 @default(now())
  endsAt                DateTime?

  stripeId              String?

  // Relations
  couple                Couple                   @relation(fields: [coupleId], references: [id], onDelete: Cascade)

  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt

  @@index([coupleId])
  @@index([endsAt])
}

// UserProfile - Extended user data (V2)
model UserProfile {
  id                    String                   @id @default(cuid())
  userId                String                   @unique

  surname               String?
  profilePhotoUrl       String?
  dateOfBirth           DateTime?

  // Work info
  weeklyWorkHours       Int                      @default(40)
  workMode              String                   @default("presencial")  // presencial, teletrabajo, hibrido
  workSchedule          String?                  // JSON string

  // Preferences
  taskPreferencesLoves  String                   @default("[]")  // JSON array
  taskPreferencesDislikes String                 @default("[]")  // JSON array

  // Relations
  user                  User                     @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt

  @@index([userId])
}

// CoupleProfile - Home/household data (V2)
model CoupleProfile {
  id                    String                   @id @default(cuid())
  coupleId              String                   @unique

  homeType              String?                  // piso, casa, otro
  homeSizeM2            Int?

  cohabitation          String?                  // JSON string
  externalServices      String?                  // JSON string (cleaners, babysitters, etc)

  isActive              Boolean                  @default(true)

  // Relations
  couple                Couple                   @relation(fields: [coupleId], references: [id], onDelete: Cascade)

  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt

  @@index([coupleId])
}

// Child - Children management (V2)
model Child {
  id                    String                   @id @default(cuid())
  coupleId              String

  name                  String
  dateOfBirth           DateTime
  livesWithUser1        Boolean                  @default(true)
  livesWithUser2        Boolean                  @default(true)
  hasSpecialNeeds       Boolean                  @default(false)

  // Relations
  couple                Couple                   @relation(fields: [coupleId], references: [id], onDelete: Cascade)

  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt

  @@index([coupleId])
}

// Pet - Pets management (V2)
model Pet {
  id                    String                   @id @default(cuid())
  coupleId              String

  name                  String
  type                  String                   // perro, gato, otro
  quantity              Int                      @default(1)

  // Relations
  couple                Couple                   @relation(fields: [coupleId], references: [id], onDelete: Cascade)

  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt

  @@index([coupleId])
}

// Invitation - Partner invitation system (V2)
model Invitation {
  id                    String                   @id @default(cuid())
  fromUserId            String
  toEmail               String?
  toUserId              String?
  token                 String                   @unique
  type                  String                   // "email_invite" | "user_proposal"
  status                String                   @default("pending")  // pending, accepted, rejected
  coupleId              String?
  expiresAt             DateTime

  // Relations
  fromUser              User                     @relation("InvitationsSent", fields: [fromUserId], references: [id], onDelete: Cascade)
  toUser                User?                    @relation("InvitationsReceived", fields: [toUserId], references: [id], onDelete: Cascade)
  couple                Couple?                  @relation(fields: [coupleId], references: [id], onDelete: SetNull)

  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt

  @@index([fromUserId])
  @@index([toEmail])
  @@index([toUserId])
  @@index([token])
  @@index([expiresAt])
}

// Category - Event/Task categories (V2)
model Category {
  id                    String                   @id @default(cuid())
  coupleId              String

  name                  String
  emoji                 String
  type                  String                   // event, chore, service
  basePoints            Decimal                  @default(10)
  description           String?

  isCustom              Boolean                  @default(false)  // false = base, true = couple created
  isActive              Boolean                  @default(true)

  // Relations
  couple                Couple                   @relation(fields: [coupleId], references: [id], onDelete: Cascade)
  subcategories         Subcategory[]

  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt

  @@index([coupleId])
  @@index([type])
  @@index([isCustom])
}

// Subcategory - Event/Task subcategories (V2)
model Subcategory {
  id                    String                   @id @default(cuid())
  categoryId            String

  name                  String
  basePointsModifier    Decimal                  @default(0)  // Can be +5, -3, ×1.2 etc

  // Relations
  category              Category                 @relation(fields: [categoryId], references: [id], onDelete: Cascade)

  createdAt             DateTime                 @default(now())
  updatedAt             DateTime                 @updatedAt

  @@index([categoryId])
}

// Achievement - Gamification achievements (V2)
model Achievement {
  id                    String                   @id @default(cuid())
  coupleId              String

  type                  String                   // solo, couple
  name                  String
  description           String
  icon                  String
  rarity                String                   // common, rare, epic, legendary
  condition             String?                  // JSON condition

  // Relations
  couple                Couple                   @relation(fields: [coupleId], references: [id], onDelete: Cascade)
  userAchievements      UserAchievement[]

  createdAt             DateTime                 @default(now())

  @@index([coupleId])
  @@index([type])
}

// UserAchievement - When user unlocked achievement (V2)
model UserAchievement {
  id                    String                   @id @default(cuid())
  userId                String
  achievementId         String

  // Relations
  user                  User?                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement           Achievement              @relation(fields: [achievementId], references: [id], onDelete: Cascade)

  unlockedAt            DateTime                 @default(now())

  @@unique([userId, achievementId])
  @@index([userId])
  @@index([achievementId])
}

// CoupleScore - Weekly couple score snapshots (V2)
model CoupleScore {
  id                    String                   @id @default(cuid())
  coupleId              String

  weekStartDate         DateTime
  user1Score            Decimal                  @default(50)
  user2Score            Decimal                  @default(50)
  overallScore          Decimal                  @default(50)

  equilibrium           Decimal                  @default(0)
  activity              Decimal                  @default(0)
  consensus             Decimal                  @default(0)
  constancy             Decimal                  @default(0)

  // Relations
  couple                Couple                   @relation(fields: [coupleId], references: [id], onDelete: Cascade)

  createdAt             DateTime                 @default(now())

  @@unique([coupleId, weekStartDate])
  @@index([coupleId])
  @@index([weekStartDate])
}

// CalendarEntry - Calendar events (V2)
model CalendarEntry {
  id                    String                   @id @default(cuid())
  coupleId              String

  type                  String                   // event, task, service, birthday, holiday
  title                 String
  date                  DateTime

  relatedEventId        String?
  relatedTaskId         String?
  description           String?
  color                 String?

  // Relations
  couple                Couple                   @relation(fields: [coupleId], references: [id], onDelete: Cascade)

  createdAt             DateTime                 @default(now())

  @@index([coupleId])
  @@index([date])
  @@index([type])
}
