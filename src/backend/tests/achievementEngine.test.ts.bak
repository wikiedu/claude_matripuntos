import { describe, it, expect, beforeEach, afterEach } from '@jest/globals'
import { PrismaClient } from '@prisma/client'
import { AchievementEngine } from '../src/services/achievementEngine'

describe('AchievementEngine', () => {
  let prisma: PrismaClient
  let engine: AchievementEngine
  let testCoupleId: string
  let testUserId: string

  beforeEach(async () => {
    prisma = new PrismaClient()
    engine = new AchievementEngine(prisma)

    // Create test couple
    const couple = await prisma.couple.create({
      data: {
        secretKey: `test-key-${Date.now()}`,
      },
    })
    testCoupleId = couple.id

    // Create test user
    const user = await prisma.user.create({
      data: {
        coupleId: testCoupleId,
        email: `test-${Date.now()}@example.com`,
        passwordHash: 'test',
        name: 'Test User',
      },
    })
    testUserId = user.id
  })

  afterEach(async () => {
    // Cleanup
    await prisma.couple.delete({ where: { id: testCoupleId } })
    await prisma.$disconnect()
  })

  describe('checkPointMilestones', () => {
    it('should unlock "Primeros pasos" achievement at 50 points', async () => {
      // Create an achievement
      const achievement = await prisma.achievement.create({
        data: {
          coupleId: testCoupleId,
          type: 'solo',
          name: 'Primeros pasos',
          description: 'Reached 50 points',
          icon: '🏁',
          rarity: 'common',
        },
      })

      // Create a points transaction
      await prisma.pointsTransaction.create({
        data: {
          coupleId: testCoupleId,
          userId: testUserId,
          type: 'event_accepted',
          amount: 50,
        },
      })

      // Check achievements
      const result = await engine.checkPointMilestones(testUserId, testCoupleId)

      expect(result).toHaveLength(1)
      expect(result[0].name).toBe('Primeros pasos')
    })

    it('should unlock "Centinela" achievement at 250 points', async () => {
      const achievement = await prisma.achievement.create({
        data: {
          coupleId: testCoupleId,
          type: 'solo',
          name: 'Centinela',
          description: 'Reached 250 points',
          icon: '🛡️',
          rarity: 'rare',
        },
      })

      // Create multiple transactions totaling 250 points
      await prisma.pointsTransaction.create({
        data: {
          coupleId: testCoupleId,
          userId: testUserId,
          type: 'event_accepted',
          amount: 150,
        },
      })

      await prisma.pointsTransaction.create({
        data: {
          coupleId: testCoupleId,
          userId: testUserId,
          type: 'event_accepted',
          amount: 100,
        },
      })

      const result = await engine.checkPointMilestones(testUserId, testCoupleId)

      expect(result).toHaveLength(1)
      expect(result[0].name).toBe('Centinela')
    })

    it('should not unlock achievement if points are below threshold', async () => {
      const achievement = await prisma.achievement.create({
        data: {
          coupleId: testCoupleId,
          type: 'solo',
          name: 'Primeros pasos',
          description: 'Reached 50 points',
          icon: '🏁',
          rarity: 'common',
        },
      })

      // Create transaction with less than 50 points
      await prisma.pointsTransaction.create({
        data: {
          coupleId: testCoupleId,
          userId: testUserId,
          type: 'event_accepted',
          amount: 30,
        },
      })

      const result = await engine.checkPointMilestones(testUserId, testCoupleId)

      expect(result).toHaveLength(0)
    })

    it('should not unlock achievement twice', async () => {
      const achievement = await prisma.achievement.create({
        data: {
          coupleId: testCoupleId,
          type: 'solo',
          name: 'Primeros pasos',
          description: 'Reached 50 points',
          icon: '🏁',
          rarity: 'common',
        },
      })

      await prisma.pointsTransaction.create({
        data: {
          coupleId: testCoupleId,
          userId: testUserId,
          type: 'event_accepted',
          amount: 50,
        },
      })

      // Check first time
      const result1 = await engine.checkPointMilestones(testUserId, testCoupleId)
      expect(result1).toHaveLength(1)

      // Check second time
      const result2 = await engine.checkPointMilestones(testUserId, testCoupleId)
      expect(result2).toHaveLength(0)
    })
  })

  describe('checkBehaviorAchievements', () => {
    it('should unlock "Pacifista" when event accepted without negotiations', async () => {
      const achievement = await prisma.achievement.create({
        data: {
          coupleId: testCoupleId,
          type: 'solo',
          name: 'Pacifista',
          description: 'Accept event without negotiations',
          icon: '☮️',
          rarity: 'common',
        },
      })

      // Create an event without negotiations
      const event = await prisma.event.create({
        data: {
          coupleId: testCoupleId,
          createdBy: testUserId,
          type: 'absence',
          dateStart: new Date(),
          dateEnd: new Date(),
          numChildren: 0,
          pointsBase: 10,
          pointsCalculated: 10,
          status: 'accepted',
        },
      })

      const result = await engine.checkBehaviorAchievements(testUserId, testCoupleId, {
        type: 'event_accepted',
        eventId: event.id,
      })

      expect(result).toHaveLength(1)
      expect(result[0].name).toBe('Pacifista')
    })

    it('should not unlock "Pacifista" when event has negotiations', async () => {
      const achievement = await prisma.achievement.create({
        data: {
          coupleId: testCoupleId,
          type: 'solo',
          name: 'Pacifista',
          description: 'Accept event without negotiations',
          icon: '☮️',
          rarity: 'common',
        },
      })

      // Create event with negotiations
      const event = await prisma.event.create({
        data: {
          coupleId: testCoupleId,
          createdBy: testUserId,
          type: 'absence',
          dateStart: new Date(),
          dateEnd: new Date(),
          numChildren: 0,
          pointsBase: 10,
          pointsCalculated: 10,
          status: 'accepted',
        },
      })

      await prisma.negotiation.create({
        data: {
          eventId: event.id,
          roundNumber: 1,
          responseType: 'accepted',
        },
      })

      const result = await engine.checkBehaviorAchievements(testUserId, testCoupleId, {
        type: 'event_accepted',
        eventId: event.id,
      })

      expect(result).toHaveLength(0)
    })

    it('should unlock "Velocidad" when completing 10+ tasks in a week', async () => {
      const achievement = await prisma.achievement.create({
        data: {
          coupleId: testCoupleId,
          type: 'solo',
          name: 'Velocidad',
          description: 'Complete 10 tasks in a week',
          icon: '⚡',
          rarity: 'rare',
        },
      })

      // Create a task
      const task = await prisma.task.create({
        data: {
          coupleId: testCoupleId,
          name: 'Test Task',
          category: 'cocina',
          pointsBase: 5,
        },
      })

      // Create 10 task logs within the last 7 days
      const weekAgo = new Date(Date.now() - 6 * 24 * 60 * 60 * 1000)
      for (let i = 0; i < 10; i++) {
        await prisma.taskLog.create({
          data: {
            coupleId: testCoupleId,
            taskId: task.id,
            completedBy: testUserId,
            date: new Date(weekAgo.getTime() + i * 24 * 60 * 60 * 1000),
            pointsBase: 5,
            pointsFinal: 5,
            status: 'verified',
          },
        })
      }

      const result = await engine.checkBehaviorAchievements(testUserId, testCoupleId, {
        type: 'manual_check',
      })

      expect(result).toContainEqual(expect.objectContaining({ name: 'Velocidad' }))
    })
  })

  describe('checkStreakAchievements', () => {
    it('should unlock "Semana tranquila" when no disputes in last 7 days', async () => {
      const achievement = await prisma.achievement.create({
        data: {
          coupleId: testCoupleId,
          type: 'couple',
          name: 'Semana tranquila',
          description: 'No disputes for a week',
          icon: '🌙',
          rarity: 'common',
        },
      })

      // Create task logs without disputes
      const task = await prisma.task.create({
        data: {
          coupleId: testCoupleId,
          name: 'Test Task',
          category: 'cocina',
          pointsBase: 5,
        },
      })

      const weekAgo = new Date(Date.now() - 6 * 24 * 60 * 60 * 1000)
      await prisma.taskLog.create({
        data: {
          coupleId: testCoupleId,
          taskId: task.id,
          completedBy: testUserId,
          date: weekAgo,
          pointsBase: 5,
          pointsFinal: 5,
          status: 'verified',
        },
      })

      const result = await engine.checkStreakAchievements(testUserId, testCoupleId)

      expect(result).toHaveLength(1)
      expect(result[0].name).toBe('Semana tranquila')
    })

    it('should not unlock "Semana tranquila" when disputes exist in last 7 days', async () => {
      const achievement = await prisma.achievement.create({
        data: {
          coupleId: testCoupleId,
          type: 'couple',
          name: 'Semana tranquila',
          description: 'No disputes for a week',
          icon: '🌙',
          rarity: 'common',
        },
      })

      // Create a disputed task log
      const task = await prisma.task.create({
        data: {
          coupleId: testCoupleId,
          name: 'Test Task',
          category: 'cocina',
          pointsBase: 5,
        },
      })

      const weekAgo = new Date(Date.now() - 6 * 24 * 60 * 60 * 1000)
      await prisma.taskLog.create({
        data: {
          coupleId: testCoupleId,
          taskId: task.id,
          completedBy: testUserId,
          date: weekAgo,
          pointsBase: 5,
          pointsFinal: 5,
          status: 'disputed',
          disputeReason: 'Test dispute',
        },
      })

      const result = await engine.checkStreakAchievements(testUserId, testCoupleId)

      expect(result).toHaveLength(0)
    })
  })

  describe('updateCoupleScore', () => {
    it('should update couple score when achievement is unlocked', async () => {
      const achievement = await prisma.achievement.create({
        data: {
          coupleId: testCoupleId,
          type: 'solo',
          name: 'Pacifista',
          description: 'Accept without negotiations',
          icon: '☮️',
          rarity: 'common',
        },
      })

      // Call updateCoupleScore via checkAchievements
      await engine.checkAchievements(testUserId, testCoupleId, { type: 'manual_check' })

      // Verify score was created/updated
      const weekStart = new Date()
      weekStart.setUTCDate(weekStart.getUTCDate() - (weekStart.getUTCDay() || 7) + 1)
      weekStart.setUTCHours(0, 0, 0, 0)

      const score = await prisma.coupleScore.findUnique({
        where: { coupleId_weekStartDate: { coupleId: testCoupleId, weekStartDate: weekStart } },
      })

      expect(score).toBeDefined()
    })

    it('should apply rarity boost to appropriate score dimension', async () => {
      const achievement = await prisma.achievement.create({
        data: {
          coupleId: testCoupleId,
          type: 'solo',
          name: 'Consenso perfecto',
          description: 'Perfect consensus',
          icon: '✨',
          rarity: 'epic',
        },
      })

      // Create 5 accepted events without counter proposals
      for (let i = 0; i < 5; i++) {
        await prisma.event.create({
          data: {
            coupleId: testCoupleId,
            createdBy: testUserId,
            type: 'absence',
            dateStart: new Date(),
            dateEnd: new Date(),
            numChildren: 0,
            pointsBase: 10,
            pointsCalculated: 10,
            status: 'accepted',
          },
        })
      }

      await engine.checkBehaviorAchievements(testUserId, testCoupleId, { type: 'manual_check' })

      // Score should exist
      const weekStart = new Date()
      weekStart.setUTCDate(weekStart.getUTCDate() - (weekStart.getUTCDay() || 7) + 1)
      weekStart.setUTCHours(0, 0, 0, 0)

      const score = await prisma.coupleScore.findUnique({
        where: { coupleId_weekStartDate: { coupleId: testCoupleId, weekStartDate: weekStart } },
      })

      expect(score).toBeDefined()
      // Consensus should be increased for this achievement
      if (score) {
        expect(score.consensus).toBeGreaterThan(50)
      }
    })
  })

  describe('Missing methods', () => {
    it('getAllAchievements should return achievements for couple', async () => {
      const achievement = await prisma.achievement.create({
        data: {
          coupleId: testCoupleId,
          type: 'solo',
          name: 'Test Achievement',
          description: 'Test',
          icon: '🎯',
          rarity: 'common',
        },
      })

      const result = await engine.getAllAchievements(testCoupleId)

      expect(result.length).toBeGreaterThan(0)
      expect(result).toContainEqual(expect.objectContaining({ name: 'Test Achievement' }))
    })

    it('getUserAchievements should return user unlocked achievements', async () => {
      const achievement = await prisma.achievement.create({
        data: {
          coupleId: testCoupleId,
          type: 'solo',
          name: 'Test Achievement',
          description: 'Test',
          icon: '🎯',
          rarity: 'common',
        },
      })

      await prisma.userAchievement.create({
        data: {
          userId: testUserId,
          achievementId: achievement.id,
        },
      })

      const result = await engine.getUserAchievements(testUserId)

      expect(result).toHaveLength(1)
      expect(result[0].achievement.name).toBe('Test Achievement')
    })

    it('checkAndUnlockAchievements should trigger manual_check', async () => {
      const achievement = await prisma.achievement.create({
        data: {
          coupleId: testCoupleId,
          type: 'solo',
          name: 'Primeros pasos',
          description: 'Test',
          icon: '🏁',
          rarity: 'common',
        },
      })

      await prisma.pointsTransaction.create({
        data: {
          coupleId: testCoupleId,
          userId: testUserId,
          type: 'event_accepted',
          amount: 50,
        },
      })

      const result = await engine.checkAndUnlockAchievements(testUserId)

      // Should unlock achievements via manual_check
      expect(result.length).toBeGreaterThanOrEqual(0)
    })

    it('getCoupleStats should return stats', async () => {
      const result = await engine.getCoupleStats(testCoupleId)

      expect(result).toHaveProperty('coupleId', testCoupleId)
      expect(result).toHaveProperty('totalAchievementsUnlocked')
      expect(result).toHaveProperty('totalTasksCompleted')
    })

    it('getCoupleScore should return score dimensions', async () => {
      const result = await engine.getCoupleScore(testCoupleId)

      expect(result).toHaveProperty('equilibrium')
      expect(result).toHaveProperty('activity')
      expect(result).toHaveProperty('consensus')
      expect(result).toHaveProperty('constancy')
    })

    it('getLeaderboard should return top couples', async () => {
      const result = await engine.getLeaderboard(10)

      expect(Array.isArray(result)).toBe(true)
    })

    it('getWeeklySummary should return week data', async () => {
      const result = await engine.getWeeklySummary(testCoupleId)

      expect(result).toHaveProperty('weekStart')
      expect(result).toHaveProperty('weekEnd')
      expect(result).toHaveProperty('pointsTransactions')
      expect(result).toHaveProperty('tasksCompleted')
      expect(result).toHaveProperty('achievementsUnlocked')
    })
  })
})
