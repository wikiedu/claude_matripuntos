# Matripuntos backend — variables de entorno
# v2.7.4 audit 10 S2-I-2 — consolidado de todas las env vars usadas en
# src/backend/src/. Copia a .env (local) o configura en Render dashboard
# (producción). Las marcadas REQUIRED fallan al boot si faltan.

# === Core (REQUIRED) ===
JWT_SECRET=replace-with-32-byte-random-string-min-length-32-chars
DATABASE_URL=postgresql://user:pass@host:5432/dbname?schema=public
PORT=3000
NODE_ENV=development   # development | production | test

# === Frontend / CORS ===
FRONTEND_URL=http://localhost:5173                          # legacy, single origin
FRONTEND_URLS=http://localhost:5173,http://localhost:4173   # multi-origen (CSV)

# === Email (Resend) — opcional, sin él el flujo email queda en no-op ===
RESEND_API_KEY=re_xxx
RESEND_FROM=Matripuntos <noreply@matripuntos.app>
PASSWORD_RESET_BASE_URL=https://matripuntos.com/reset-password

# === Google Calendar OAuth (v2.0.1+, opcional, stub si no se setea) ===
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_REDIRECT_URI=http://localhost:5173/oauth/google/callback
GOOGLE_TOKEN_ENCRYPTION_KEY=replace-with-32-byte-hex-key

# === Telemetría / monitoring (opcional) ===
POSTHOG_KEY=
POSTHOG_HOST=https://eu.posthog.com
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.1

# === Build/version metadata (auto-set en Render) ===
APP_VERSION=
COMMIT_SHA=
GIT_COMMIT=
RENDER_GIT_COMMIT=

# === Feature flags (default ON salvo nota) ===
ANALYTICS_V2_ENABLED=true
ANNIVERSARY_ENABLED=true
CALENDAR_V2_ENABLED=true
CATALOG_ENABLED=true
CATALOG_AUTOSEED=true
CONFIG_PROPOSALS_ENABLED=true
DEMO_MODE_ENABLED=false      # seed demo accesible — solo dev
GAMIFICATION_V2_ENABLED=true
JOURNAL_ENABLED=true
POINTS_RESET_ENABLED=false   # endpoint flag-gated, peligroso
TASK_PROOF_ENABLED=true
